# =============================================================================
#  PRISMA — MySQL 8.4 tuning
#  Compatível com MySQL 8.4 (opções depreciadas removidas)
# =============================================================================

[mysqld]
# ── Character set ────────────────────────────────────────────────────────────
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci
# skip-character-set-client-handshake foi removida no MySQL 8.4

# ── Connections ───────────────────────────────────────────────────────────────
max_connections       = 300
max_connect_errors    = 10000
wait_timeout          = 28800
interactive_timeout   = 28800

# ── InnoDB performance ────────────────────────────────────────────────────────
innodb_buffer_pool_size         = 512M
innodb_buffer_pool_instances    = 4
# innodb_redo_log_capacity substitui innodb_log_file_size no MySQL 8.4
innodb_redo_log_capacity        = 268435456
innodb_log_buffer_size          = 64M
innodb_flush_log_at_trx_commit  = 2
innodb_flush_method             = O_DIRECT
innodb_file_per_table           = 1
innodb_read_io_threads          = 8
innodb_write_io_threads         = 8

# ── Slow query log ────────────────────────────────────────────────────────────
slow_query_log      = 1
slow_query_log_file = /var/lib/mysql/slow.log
long_query_time     = 2

# ── Binary log ────────────────────────────────────────────────────────────────
log_bin             = mysql-bin
# binlog_format = ROW é o padrão no MySQL 8.4, não precisa declarar
expire_logs_days    = 7

# ── Misc ──────────────────────────────────────────────────────────────────────
sql_mode            = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION
max_allowed_packet  = 64M
tmp_table_size      = 64M
max_heap_table_size = 64M

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
