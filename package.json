{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "docker:up": "docker compose --profile dev up -d",
        "docker:down": "docker compose down",
        "docker:build": "docker compose build --no-cache",
        "docker:logs": "docker compose logs -f app queue reverb",
        "docker:reset": "docker compose down -v && docker compose --profile dev up -d --build"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
